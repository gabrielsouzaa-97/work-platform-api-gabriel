###############################################################################
# mework360-deployer — .env.example
# Commitado SEM valores reais. Copiar para .env e preencher.
# Regra: nenhum secret real neste arquivo (placeholders apenas).
###############################################################################

# --- Application ---
APP_NAME="mework360-deployer"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://mework360.local
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Docker ports (host side) ---
NGINX_PORT=8080
DB_EXTERNAL_PORT=3306
REDIS_EXTERNAL_PORT=6379
MAIL_EXTERNAL_PORT=1025
MAILPIT_UI_PORT=8025

# --- Xdebug (Docker app -> Cursor/VSCode) ---
XDEBUG_MODE=debug,develop
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9003
XDEBUG_START_WITH_REQUEST=yes
XDEBUG_IDEKEY=VSCODE
PHP_IDE_CONFIG=serverName=mework360.local

# --- Database (MariaDB 11) ---
DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=mework360_deployer
DB_USERNAME=mework360_deployer
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# --- Redis (cache, sessão, rate limit, retry de email) ---
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Cache & Session & Queue ---
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
QUEUE_CONNECTION=redis

# --- Broadcasting / Filesystem ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail (Mailpit em dev; SMTP real em prod) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@mework360.local"
MAIL_FROM_NAME="${APP_NAME}"

###############################################################################
# Integração com upstream (nextcloud-saas-manager)
# SSH keys e webhook secrets são armazenados em DB via Laravel Encrypted Storage
# (tabela cluster_servers). Estas variáveis são apenas para overrides locais.
###############################################################################

# --- Webhook Receiver (POST /api/jobs/hook) ---
WEBHOOK_REPLAY_WINDOW_SECONDS=3600
WEBHOOK_RATE_LIMIT_PER_MIN=100

# --- SSH Client (timeouts e retries para manage.sh) ---
SSH_CONNECT_TIMEOUT_SECONDS=10
SSH_COMMAND_TIMEOUT_SECONDS=60
SSH_MAX_RETRIES=3

###############################################################################
# Backups e Object Storage (produção)
# No dev, estas variáveis ficam vazias. Em produção, configurar via secret.
###############################################################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=mework360-deployer-backups
AWS_USE_PATH_STYLE_ENDPOINT=false

###############################################################################
# Observabilidade (opcional)
###############################################################################
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
